      <aliases enabled='yes' />
      <column caption='Accel Sec' datatype='real' name='[AccelSec]' role='measure' type='quantitative' />
      <column caption='Body Style' datatype='string' name='[BodyStyle]' role='dimension' type='nominal' />
      <column caption=' Range(Miles)' datatype='real' name='[Calculation_1170449763299330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Range_Km] * 0.621371' />
      </column>
      <column caption=' Top Speed (MPH)' datatype='real' name='[Calculation_1170449765105667]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[TopSpeed_KmH] * 0.621371' />
      </column>
      <column caption='Fast Charge (Km/Minute)' datatype='real' name='[Calculation_1170449765158916]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[FastCharge_KmH] / 60' />
      </column>
      <column caption='Efficiency (Km/kWh)' datatype='real' name='[Calculation_1170449765183493]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1000 / [Efficiency_WhKm]' />
      </column>
      <column caption='Performance Score' datatype='real' name='[Calculation_1170449765351430]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Range_Km] / [AccelSec]' />
      </column>
      <column caption='Price per Km' datatype='real' name='[Calculation_1170449765556231]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[PriceEuro] / [Range_Km]' />
      </column>
      <column caption='High Range Vehicle' datatype='string' name='[Calculation_1170449765629960]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Range_Km] &gt;= 400 THEN&#13;&#10;    &quot;High Range&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Standard Range&quot;&#13;&#10;END' />
      </column>
      <column caption='Luxury Vehicle' datatype='string' name='[Calculation_1170449765703689]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PriceEuro] &gt;= 50000 THEN&#13;&#10;    &quot;Luxury&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Budget&quot;&#13;&#10;END' />
      </column>
      <column caption='Fast Charging Category' datatype='string' name='[Calculation_1170449765781514]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [FastCharge_KmH] &gt;= 500 THEN&#13;&#10;    &quot;Ultra Fast&quot;&#13;&#10;ELSEIF [FastCharge_KmH] &gt;= 300 THEN&#13;&#10;    &quot;Fast&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Seating Category' datatype='string' name='[Calculation_1170449765871628]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Seats] &gt;= 7 THEN&#13;&#10;    &quot;Large Family&quot;&#13;&#10;ELSEIF [Seats] &gt;= 5 THEN&#13;&#10;    &quot;Standard Family&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Compact&quot;&#13;&#10;END' />
      </column>
      <column caption='Record Count.' datatype='integer' name='[Calculation_1170449769697293]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Efficiency WhKm' datatype='integer' name='[Efficiency_WhKm]' role='measure' type='quantitative' />
      <column caption='FastCharge KmH' datatype='integer' name='[FastCharge_KmH]' role='measure' type='quantitative' />
